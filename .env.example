# ============================================
# Antigravity Skills — Environment Variables
# ============================================
# Скопируйте этот файл как .env и заполните значения:
#   copy .env.example .env
# ============================================

# --- MVP (Этап 1) ---

# Supabase — Source of Truth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# DB URL — используйте Session pooler (НЕ Direct connection!)
# Найти: Supabase Dashboard → Settings → Database → Connection string → Session pooler → URI
# Формат: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Telegram Bot — Основной UI
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHAT_ID=your-personal-chat-id

# LLM API (ProxyAPI) — Генерация текстов
LLM_API_URL=https://api.proxyapi.ru
LLM_API_KEY=your-proxyapi-key

# FastAPI — внутренний API (вызывается из n8n)
API_SECRET_KEY=generate-a-random-key-here

# --- Этап 2 (не критичны для MVP) ---

# Google Sheets — Отчёты
GOOGLE_SHEETS_CREDENTIALS_PATH=./credentials/google_sheets.json
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# Notion — Портфолио и база знаний
NOTION_API_KEY=secret_your-notion-key
NOTION_DATABASE_ID=your-database-id

# n8n — Оркестратор
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key
