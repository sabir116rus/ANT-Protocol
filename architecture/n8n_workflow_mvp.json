      "position": [
        1140,
        120
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.FASTAPI_URL || 'http://host.docker.internal:8000' }}/api/tasks/list",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-API-Key",
              "value": "={{ $env.API_SECRET_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ telegram_chat_id: $('Parse Command').first().json.chat_id, task_date: $('Parse Command').first().json.args || null }) }}",
        "options": {}
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000006",
      "name": "HTTP List Tasks",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1140,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.FASTAPI_URL || 'http://host.docker.internal:8000' }}/api/tasks/status",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-API-Key",
              "value": "={{ $env.API_SECRET_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ telegram_chat_id: $('Parse Command').first().json.chat_id, task_number: parseInt($('Parse Command').first().json.args) || 1, new_status: 'done' }) }}",
        "options": {}
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000007",
      "name": "HTTP Done Task",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1140,
        480
      ]
    },
    {
      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst chatId = $('Parse Command').first().json.chat_id;\n\nif (!resp.ok) {\n  return [{ json: { chat_id: chatId, text: '❌ ' + (resp.error || 'Unknown error') } }];\n}\n\nconst t = resp.task;\nconst priorityEmoji = { high: '🔴', medium: '🟡', low: '🟢' };\n\nconst text = \\nconst dAdd = t.task_date ? t.task_date.split('-') : [];\\nconst fDateAdd = dAdd.length === 3 ? `${dAdd[2]}.${dAdd[1]}.${dAdd[0]}` : t.task_date;\\n\\nconst text = `✅ Задача добавлена\\n\\n${priorityEmoji[t.priority] || '🟡'} ${t.title}\\n📅 ${fDateAdd}\\n⏱ ${t.estimated_minutes} мин`;\n\nreturn [{ json: { chat_id: chatId, text: text } }];"
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000008",
      "name": "Format Add",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1380,
        120
      ]
    },
    {
      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst chatId = $('Parse Command').first().json.chat_id;\n\nif (!resp.ok) {\n  return [{ json: { chat_id: chatId, text: '❌ ' + (resp.error || 'Unknown error') } }];\n}\n\nif (resp.count === 0) {\n  return [{ json: { chat_id: chatId, text: '📋 Задач на сегодня нет.\\nДобавьте через /add' } }];\n}\n\nconst statusIcon = { pending: '⬜', in_progress: '🔄', done: '✅', cancelled: '🚫' };\nconst priorityIcon = { high: '🔴', medium: '🟡', low: '🟢' };\n\nconst dList = resp.task_date ? resp.task_date.split('-') : [];\\nconst fDateList = dList.length === 3 ? `${dList[2]}.${dList[1]}.${dList[0]}` : resp.task_date;\\n\\nlet lines = [`📋 Задачи на ${fDateList}\\n`];\nfor (const t of resp.tasks) {\n  const s = statusIcon[t.status] || '⬜';\n  const p = priorityIcon[t.priority] || '🟡';\n  lines.push(`${s} ${t.number}. ${p} ${t.title} (${t.estimated_minutes} мин)`);\n}\nlines.push(`\\n📊 Всего: ${resp.count}/7`);\n\nreturn [{ json: { chat_id: chatId, text: lines.join('\\n') } }];"
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000009",
      "name": "Format List",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1380,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst chatId = $('Parse Command').first().json.chat_id;\n\nif (!resp.ok) {\n  return [{ json: { chat_id: chatId, text: '❌ ' + (resp.error || 'Unknown error') } }];\n}\n\nconst statusText = { done: '✅ Выполнено', cancelled: '🚫 Отменено', pending: '⬜ Возвращено' };\nconst label = statusText[resp.new_status] || '✅';\n\nconst text = `${label} #${resp.task_number}: ${resp.title}`;\n\nreturn [{ json: { chat_id: chatId, text: text } }];"
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000010",
      "name": "Format Done",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1380,
        480
      ]
    },
    {
      "parameters": {
        "jsCode": "const chatId = $json.chat_id;\nconst text = '❓ Неизвестная команда.\\n\\nДоступные:\\n/add Название — добавить задачу\\n/list — список задач\\n/done N — выполнить задачу #N';\n\nreturn [{ json: { chat_id: chatId, text: text } }];"
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000011",
      "name": "Format Help",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1380,
        660
      ]
    },
