      },
      "id": "a1b2c3d4-0001-0001-0001-000000000001",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [
        220,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Parse command and args from Telegram message\nconst text = ($input.first().json.message?.text || '').trim();\nconst parts = text.split(/\\s+/);\nconst command = (parts[0] || '').toLowerCase();\nconst args = parts.slice(1).join(' ');\n\nreturn [{\n  json: {\n    chat_id: $input.first().json.message?.chat?.id,\n    command: command,\n    args: args,\n    username: $input.first().json.message?.from?.username || '',\n    first_name: $input.first().json.message?.from?.first_name || ''\n  }\n}];"
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000002",
      "name": "Parse Command",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": ""
          },
          "conditions": [
            {
              "id": "auth-check",
              "leftValue": "={{ String($json.chat_id) }}",
              "rightValue": "={{ String($env.TELEGRAM_CHAT_ID) }}",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000003",
      "name": "Auth Check",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        660,
        300
      ]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "outputIndex": 0,
              "value": "/add"
            },
            {
              "outputIndex": 1,
              "value": "/list"
            },
            {
              "outputIndex": 2,
              "value": "/done"
            }
          ]
        },
        "fallbackOutput": 3,
        "dataType": "string",
        "value": "={{ $json.command }}"
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000004",
      "name": "Command Router",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        880,
        300
      ]
    },
    {
      "parameters": {
