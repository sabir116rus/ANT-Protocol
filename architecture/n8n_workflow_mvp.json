        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ telegram_chat_id: $json.chat_id, title: $json.args || 'Untitled' }) }}",
        "options": {}
      },
      "id": "a1b2c3d4-0001-0001-0001-000000000005",
      "name": "HTTP Add Task",
      "type": "n8n-nodes-base.httpRequest",
